{
  "name": "desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "start": "concurrently -k -n VITE,ELECTRON -c blue,green \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.snehpatel.jobscraper",
    "productName": "Kairos",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist_backend/server",
        "to": "backend"
      },
      {
        "from": "build-resources/chromium",
        "to": "chromium"
      },
      {
        "from": "build-resources/tectonic",
        "to": "tectonic"
      },
      {
        "from": "build-resources/resume-icons",
        "to": "resume-icons"
      },
      {
        "from": "build-resources/cloudflared",
        "to": "cloudflared"
      },
      {
        "from": "../mobile",
        "to": "mobile",
        "filter": [
          "**/*",
          "!.expo",
          "!.claude",
          "!.gitignore"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "identity": null
    }
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "recharts": "^3.9.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.2.3",
    "cross-env": "^7.0.3",
    "electron": "^41.7.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "wait-on": "^8.0.5"
  }
}
