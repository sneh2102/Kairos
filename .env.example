# Ollama cloud API keys — add as many as you have, they rotate on rate-limit/auth errors
OLLAMA_API_KEY_1=your_key_here
OLLAMA_API_KEY_2=

OUTPUT_DIR=outputs

# Mobile app only: shared secret the backend requires on tunnel traffic.
# Must match API_TOKEN in mobile/config.ts. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
TUNNEL_TOKEN=
